screeners = get_all_screeners()
print(f"[DEBUG] Initializing configs for {len(screeners)} screeners")

for s in screeners:
    screener_name = s['name']
    print(f"[DEBUG] Processing: {screener_name}")

    # Skip if config already exists in screener_configs table
    conn = get_db_connection()
    cursor = conn.cursor()
    cursor.execute('SELECT id FROM screener_configs WHERE screener_name = ?', (screener_name,))
    if cursor.fetchone():
        print(f"[DEBUG] Config already exists for {screener_name}, skipping")
        continue

    # Get screener schema
    module_name = screener_name.replace('.py', '')
    import importlib.util
    spec = importlib.util.spec_from_file_location(module_name, screener_name + '.py')
    module = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(module)

    schema = {}
    if hasattr(module, 'get_parameter_schema'):
        try:
            schema = module.get_parameter_schema()
        except Exception as e:
            print(f"[DEBUG] Error getting schema for {screener_name}: {e}")

    if schema:
        # Build default config
        config = {
            'display_name': s['display_name'],
            'description': s.get('description', ''),
            'category': 'technical',
            'parameters': {}
        }

        # Initialize parameters with defaults from schema
        for param_name, param_def in schema.items():
            config['parameters'][param_name] = {
                'value': param_def.get('default'),
                'display_name': param_def.get('display_name', param_name),
                'description': '',
                'group': '其他',
                'type': 'string',
                'min': param_def.get('min'),
                'max': param_def.get('max'),
                'step': param_def.get('step'),
                'default': param_def.get('default')
            }

        # Save to database
        try:
            import json
            config_json = json.dumps(config)
            schema_json = json.dumps(schema)

            conn = get_db_connection()
            cursor = conn.cursor()

            # Check if config already exists
            cursor.execute('SELECT id FROM screener_configs WHERE screener_name = ?', (screener_name,))
            exists = cursor.fetchone()

            if exists:
                print(f"[DEBUG] Config already exists for {screener_name}, skipping")
            else:
                cursor.execute('''
                    INSERT INTO screener_configs
                    (screener_name, display_name, description, category, config_json, config_schema, current_version)
                    VALUES (?, ?, ?, ?, ?, ?, ?, 'v1.0')
                ''', (screener_name, s['display_name'], s.get('description', ''), 'technical', config_json, schema_json))
                conn.commit()
                print(f"[DEBUG] Created config for {screener_name}")
        except Exception as e:
            print(f"[DEBUG] Error creating config for {screener_name}: {e}")

    conn.close()

print('[DEBUG] Config initialization complete')

