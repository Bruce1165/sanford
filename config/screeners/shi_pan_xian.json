{
  "display_name": "涨停试盘线",
  "description": "寻找涨停板后的试盘信号。三个信号条件：信号一（最大量阳线T日后5日内出现量<T的涨停X日）、信号二（X日后最低价>X日开盘价）、信号三（X日后量<T日×0.25）。",
  "category": "内部公式",
  "metadata": {
    "version": "v1.0",
    "created": "2026-04-04",
    "updated_at": "2026-04-17",
    "updated_by": "fix_3types"
  },
  "parameters": {
    "LIMIT_DAYS": {
      "value": 14,
      "display_name": "时间范围（交易日）",
      "description": "筛选最近多少个交易日内的信号",
      "group": "基础设置",
      "type": "int",
      "min": 1,
      "max": 60,
      "default": 14
    },
    "LIMIT_UP_THRESHOLD": {
      "value": 9.9,
      "display_name": "涨停阈值（%）",
      "description": "判断涨停的最低涨幅阈值",
      "group": "信号条件",
      "type": "float",
      "min": 9.0,
      "max": 10.5,
      "step": 0.1,
      "default": 9.9
    },
    "T_DAY_TOLERANCE": {
      "value": 0.95,
      "display_name": "T日成交额容忍度",
      "description": "T日成交额需要达到最大成交额的倍数（允许误差）",
      "group": "信号条件",
      "type": "float",
      "min": 0.9,
      "max": 1.0,
      "step": 0.01,
      "default": 0.95
    },
    "DAYS_AFTER_T": {
      "value": 5,
      "display_name": "T日后交易日内数",
      "description": "在T日之后多少个交易日内寻找X日（涨停板）",
      "group": "信号条件",
      "type": "int",
      "min": 3,
      "max": 10,
      "default": 5
    },
    "SIGNAL_THREE_RATIO": {
      "value": 0.25,
      "display_name": "信号三成交额比例",
      "description": "启动日成交额需要小于T日成交额的倍数",
      "group": "信号条件",
      "type": "float",
      "min": 0.15,
      "max": 0.4,
      "step": 0.05,
      "default": 0.25
    }
  }
}