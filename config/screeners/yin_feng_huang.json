{
  "display_name": "涨停银凤凰",
  "description": "寻找涨停板后的启动信号。四个信号条件：信号一（非一字板涨停，成交额≥前1日2倍）、信号二（信号一到信号四之间最低价始终>信号一开盘价）、信号三（T日收跌，成交额<T-1日）、信号四（启动日收涨，成交额≥前1日2倍）。",
  "category": "内部公式",
  "metadata": {
    "version": "v1.0",
    "created": "2026-04-04",
    "updated_at": "2026-04-17",
    "updated_by": "fix_3types"
  },
  "parameters": {
    "LIMIT_DAYS": {
      "value": 14,
      "display_name": "时间范围（交易日）",
      "description": "筛选最近多少个交易日内的信号",
      "group": "基础设置",
      "type": "int",
      "min": 1,
      "max": 60,
      "default": 14
    },
    "LIMIT_UP_THRESHOLD": {
      "value": 9.9,
      "display_name": "涨停阈值（%）",
      "description": "判断涨停的最低涨幅阈值",
      "group": "信号条件",
      "type": "float",
      "min": 9.0,
      "max": 10.5,
      "step": 0.1,
      "default": 9.9
    },
    "SIGNAL_ONE_VOLUME_RATIO": {
      "value": 2.0,
      "display_name": "信号一成交额倍数",
      "description": "信号一当日成交额需要达到前一日的倍数",
      "group": "信号条件",
      "type": "float",
      "min": 1.5,
      "max": 3.0,
      "step": 0.1,
      "default": 2.0
    },
    "SIGNAL_THREE_SHRINK_RATIO": {
      "value": 1.0,
      "display_name": "信号三缩量比例",
      "description": "信号三（T日）成交额需要小于前一日的倍数（1.0表示严格小于）",
      "group": "信号条件",
      "type": "float",
      "min": 0.8,
      "max": 1.5,
      "step": 0.05,
      "default": 1.0
    },
    "SIGNAL_FOUR_VOLUME_RATIO": {
      "value": 2.0,
      "display_name": "信号四成交额倍数",
      "description": "信号四（启动日）成交额需要达到前一日的倍数",
      "group": "信号条件",
      "type": "float",
      "min": 1.5,
      "max": 3.0,
      "step": 0.1,
      "default": 2.0
    }
  }
}